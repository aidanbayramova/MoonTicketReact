using AutoMapper;
using Domain.Entities;
using Repository.Repositories.Interfaces;
using Service.DTOs.Admin.ContactMessage;
using Service.Services.Interfaces;

namespace Service.Services
{
    public class ContactMessageService : IContactMessageService
    {
        private readonly IContactMessageRepository _contactMessageRepository;
        private readonly IMapper _mapper;
        private readonly IEmailService _emailService;

        public ContactMessageService(
            IContactMessageRepository contactMessageRepository,
            IMapper mapper,
            IEmailService emailService)
        {
            _contactMessageRepository = contactMessageRepository;
            _mapper = mapper;
            _emailService = emailService;
        }

        public async Task<List<ContactMessageDto>> GetAllAsync()
        {
            var entities = await _contactMessageRepository.GetAllOrderedAsync();
            return _mapper.Map<List<ContactMessageDto>>(entities);
        }

        public async Task<ContactMessageDto> CreateAsync(ContactMessageCreateDto dto)
        {
            var entity = _mapper.Map<ContactMessage>(dto);
            await _contactMessageRepository.CreateAsync(entity);
            return _mapper.Map<ContactMessageDto>(entity);
        }

        public async Task<bool> ReplyAsync(int id, ContactMessageReplyDto dto)
        {
            var entity = await _contactMessageRepository.GetByIdAsync(id);
            if (entity == null) return false;

            entity.AdminReply = dto.Reply;
            entity.IsReplied = true;
            entity.RepliedAt = DateTime.UtcNow;

            await _contactMessageRepository.UpdateAsync(entity);

            var fullName = $"{entity.FirstName} {entity.LastName}".Trim();
            var body = $@"
                <div style='font-family:Arial,sans-serif;line-height:1.6;color:#1f1f1f;'>
                    <h2 style='margin-bottom:8px;'>Hello {fullName},</h2>
                    <p>Thank you for contacting MoonTicket. Here is our response:</p>
                    <div style='background:#f6f6f6;border-left:4px solid #7b0d23;padding:14px 16px;margin:12px 0;'>
                        {System.Net.WebUtility.HtmlEncode(dto.Reply).Replace("\n", "<br/>")}
                    </div>
                    <p>If you have any other questions, just reply back to this email.</p>
                    <p style='margin-top:20px;'>Best regards,<br/>MoonTicket Team</p>
                </div>";

            await _emailService.SendAsync(entity.Email, "MoonTicket - Your message reply", body);
            return true;
        }
    }
}
